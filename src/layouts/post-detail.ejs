<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mini Blog</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600&display=swap"
      rel="stylesheet"
    />

    <link href="/assets/styles/tailwind.css" rel="stylesheet" />
  </head>
  <body class="bg-gray-100">
    <h1 class="mt-10 text-4xl font-semibold text-center">
      <a href="/" class="underline hover:text-blue-500">Back to The Future</a>
    </h1>
    <div class="max-w-lg p-2 mx-auto my-10">
      <div class="posts-wrapper">
        <div
          class="p-4 mb-4 bg-white border border-gray-100 border-solid rounded-md post"
        >
          <div class="flex flex-row justify-between">
            <h2 class="text-xl font-semibold text-blue-500">
              <%= post.title %>
            </h2>
            <%- include('components/likes', { postID: post._id, likes:
            post.likes }); %>
          </div>
          <div class="my-5 content">
            <p><%= post.content %></p>
          </div>
          <div
            class="flex justify-between pt-2 text-base border-t border-gray-100 border-solid post-foo"
          >
            <strong class="text-gray-500"><%= post.author %></strong>
            <em class="text-xs not-italic w-28"
              ><%= moment(post.date).format("LL") %></em
            >
          </div>
        </div>
      </div>
      <h3 class="mb-2 ml-2">Comments</h3>
      <div class="ml-10 comments-wrapper">
        <% comments.forEach((comment) =>{ %>
        <div
          class="p-2 mb-2 border-l-4 border-blue-400 border-solid bg-white comment-box"
        >
          <%= comment.comment %>
        </div>
        <% }) %>
      </div>
    </div>
  </body>
</html>
